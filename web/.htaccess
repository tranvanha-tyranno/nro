RewriteEngine On
RewriteBase /
DirectoryIndex Index.php index.php index.html

RewriteRule ^Home$ /Index.php [L]

RewriteRule ^Auth/Login$ /Pages/Auth/Login.php [L]
RewriteRule ^Auth/Register$ /Pages/Auth/Register.php [L]
RewriteRule ^Auth/Logout$ /Pages/Auth/Logout.php [L]
RewriteRule ^Auth/ForgotPassword$ /Pages/Auth/ForgotPassword.php [L]

RewriteRule ^Users/Profile$ /Pages/Users/Profile.php [L]
RewriteRule ^Users/Admin$ /Pages/Users/Admin.php [L]
RewriteRule ^Users/Payment$ /Pages/Users/Payment.php [L]
RewriteRule ^Users/Gold$ /Pages/Users/Gold.php [L]
RewriteRule ^Users/History$ /Pages/Users/History.php [L]
RewriteRule ^Users/ChangePassword$ /Pages/Users/ChangePassword.php [L]

RewriteRule ^Others/Downloads$ /Pages/Others/Downloads.php [L]
RewriteRule ^Others/Sukien$ /Pages/Others/Sukien.php [L]
RewriteRule ^Others/Tinhnang$ /Pages/Others/Tinhnang.php [L]
RewriteRule ^Others/Mocnap$ /Pages/Others/Mocnap.php [L]
RewriteRule ^Others/Top$ /Pages/Others/Top.php [L]

RewriteRule ^Api/Active$ /Api/Users/Active.php [L]
RewriteRule ^Api/Gold$ /Api/Users/Gold.php [L]
RewriteRule ^Api/Password$ /Api/Users/Password.php [L]
RewriteRule ^Api/Callback$ /Api/Users/Callback.php [L]
RewriteRule ^Api/Card$ /Api/Users/Card.php [L]
RewriteRule ^Api/Email$ /Api/Users/Email.php [L]
RewriteRule ^Api/CardHistory$ /Api/Users/CardHistory.php [L]
RewriteRule ^Api/AtmHistory$ /Api/Users/AtmHistory.php [L]

RewriteRule ^Bank/Cron$ /Api/Bank/Cron.php [L]
RewriteRule ^Bank/Login$ /Api/Bank/Login.php [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/]+)/?$ $1.php [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /Index.php [L]

ErrorDocument 404 /Home
Options -Indexes
AddType application/octet-stream .ipa

<Files .htaccess>
    order allow,deny
    deny from all
</Files>

<FilesMatch "\.(jpg|jpeg|png|gif|svg|css|js|ico)$">
    Header set Cache-Control "max-age=31536000"
</FilesMatch>
