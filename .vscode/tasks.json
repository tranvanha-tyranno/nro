{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start local database",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\local-start-db.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "Build local server",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\local-build.ps1",
        "-Clean"
      ],
      "problemMatcher": "$javac"
    },
    {
      "label": "Run local server",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\local-run.ps1"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Watch server logs",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\local-watch-logs.ps1"
      ],
      "problemMatcher": []
    }
  ]
}
